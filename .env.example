# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_anon_key
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend (email notifications)
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=noreply@sendbox.io

# Stripe (compte micro-entreprise — pas Connect)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Frais de mise en relation
# 290 = beta publique douce (2,90 EUR). Utiliser 150 uniquement pour une private beta fermee.
MATCHING_FEE_CENTS=290
MATCHING_FEE_CURRENCY=eur

# Litiges
DISPUTE_SUSPENSION_DAYS=30
ADMIN_EMAIL=

# Upload photos colis
UPLOAD_SECRET=
MAX_PHOTO_SIZE_MB=10

# Système de confiance — anti-collusion et trust score
TRANSACTION_MIN_DURATION_HOURS=24
CONCENTRATION_FLAG_RATIO_LOW=0.60
CONCENTRATION_FLAG_RATIO_HIGH=0.75
CONCENTRATION_MIN_TRANSACTIONS=5
CAP_PER_AUTHOR=0.20
REVIEW_WINDOW_DAYS=7
COLLUSION_RING_DEPTH=3

# Cron jobs (appels depuis Vercel Cron ou cron externe)
CRON_SECRET=

# OAuth Providers
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
