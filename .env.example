# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=votre_anon_key
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (à ajouter Sprint 4)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Optionnel: restreindre les pays Stripe Connect (codes ISO, ex: FR,BJ)
# NEXT_PUBLIC_STRIPE_CONNECT_ALLOWED_COUNTRIES=FR,BJ

# Resend (à ajouter Sprint 5)
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=noreply@sendbox.io

# Flutterwave (hybride payouts)
# FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-...
# FLUTTERWAVE_CLIENT_ID=FLW_CLIENT_ID
# FLUTTERWAVE_CLIENT_SECRET=FLW_CLIENT_SECRET
# FLUTTERWAVE_BASE_URL=https://developersandbox-api.flutterwave.com
# FLUTTERWAVE_WEBHOOK_SECRET=your_webhook_hash

# FedaPay (Afrique de l'Ouest)
# FEDAPAY_SECRET_KEY=YOUR_SECRET_KEY
# FEDAPAY_ENV=sandbox
# FEDAPAY_BASE_URL=https://sandbox-api.fedapay.com/v1
# FEDAPAY_WEBHOOK_SECRET=your_webhook_hash

# Upstash Redis (optionnel, Sprint 9)
# UPSTASH_REDIS_REST_URL=...
# UPSTASH_REDIS_REST_TOKEN=...
